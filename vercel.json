{
  "rewrites": [
    {
      "source": "/fakestore/:path*",
      "destination": "https://fakestoreapi.com/:path*"
    },
    {
      "source": "/dummyjson/:path*",
      "destination": "https://dummyjson.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
